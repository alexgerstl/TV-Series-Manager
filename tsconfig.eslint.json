{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client"]
  },
  "include": [
    "*.config.ts",
    "electron.vite.config.ts",
    "vitest.config.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ]
}
